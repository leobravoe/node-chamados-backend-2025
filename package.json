{
    "name": "desenvovimento-web-2025",
    "version": "1.0.0",
    "description": "AtendeAí - Organize a fila de atendimento em aulas práticas",
    "main": "index.js",
    "type": "module",
    "scripts": {
        "dev": "nodemon src/server.js",
        "start": "node src/server.js",
        "deploy": "npm install && npm run reset-database",
        "reset-database": "node src/commands/reset-database-mysql.js",
        "reset-database-test": "cross-env NODE_ENV=test DOTENV_CONFIG_PATH=.env.test node -r dotenv/config src/commands/reset-database-mysql.js",
        "test": "npm run reset-database-test && cross-env NODE_ENV=test node --experimental-vm-modules ./node_modules/jest/bin/jest.js --runInBand --detectOpenHandles --forceExit"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/leobravoe/desenvovimento-web-2025.git"
    },
    "author": "Leonardo Bravo Estácio",
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/leobravoe/desenvovimento-web-2025/issues"
    },
    "homepage": "https://github.com/leobravoe/desenvovimento-web-2025#readme",
    "dependencies": {
        "bcryptjs": "^3.0.3",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.5",
        "dotenv": "^17.2.3",
        "express": "^5.2.1",
        "express-rate-limit": "^8.2.1",
        "jsonwebtoken": "^9.0.3",
        "multer": "^2.0.2",
        "mysql2": "^3.18.2",
        "pg": "^8.16.3",
        "swagger-jsdoc": "^6.2.8",
        "swagger-ui-express": "^5.0.1"
    },
    "devDependencies": {
        "cross-env": "^10.1.0",
        "jest": "^30.2.0",
        "nodemon": "^3.1.11",
        "supertest": "^7.2.2"
    }
}
