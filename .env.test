# AMBIENTE DO PROJETO NODE
NODE_ENV=test
# PORTA DO SERVIDOR DO EXPRESS
PORT=3000
# CONFIGURAÇÃO DO BANCO
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_DATABASE=chamados_api_db_test
PG_DATABASE_ADMIN=root
DB_DATABASE_ADMIN_PASSWORD=
# CAMINHO PARA O SQL DO BANCO
DB_DATABASE_FILE_PATH=./src/database/banco-mysql.sql
# CONFIGURAÇÃO JWT
JWT_ACCESS_SECRET=teste-access
JWT_REFRESH_SECRET=teste-refresh
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
